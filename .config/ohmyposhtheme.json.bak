{
  "theme": {
    "segments": [
      {
        "type": "username",
        "style": "bg:surface1 fg:yellow",
        "format": "[оӮ¶]($style)[$user ](bold $style)",
        "show_always": true
      },
      {
        "type": "directory",
        "style": "bold bg:surface0 fg:lavender",
        "format": "[ $path ]($style)",
        "truncation_length": 3,
        "truncation_symbol": "вҖҰ/"
      },
      {
        "type": "git_branch",
        "style": "bold bg:surface1 fg:green",
        "symbol": "пҗҳ ",
        "format": "[ $symbol$branch]($style)[оӮҙ](surface1)"
      },
      {
        "type": "git_status",
        "style": "bold lavender",
        "format": "(:[$all_status$ahead_behind]($style)) ",
        "conflicted": "[п № [$count](bright-white bold)]",
        "ahead": "[[пҜҒ ](bright-blue)[$count](bright-white bold)]",
        "behind": "[[п®ҫ ](white)[$count](bright-white bold)]",
        "diverged": "[[оңЁ ](purple)|[ пҜҒ ](bright-blue)[$ahead_count](bright-white bold)[ п®ҫ ](white)[$behind_count](bright-white)]",
        "untracked": "[п„Ё [$count](bright-white bold)]",
        "stashed": "[[пЈ–](yellow) [$count](bright-white bold)]",
        "modified": "[[о«һ ](bright-yellow)[$count](bright-white bold)]",
        "staged": "[[п‘— ](bright-green)[$count](bright-white bold)]",
        "renamed": "[[п‘ҡ ](bright-cyan) [$count](bright-white bold)]",
        "deleted": "[пҖ” [$count](bright-white bold)]"
      },
      {
        "type": "cmd_duration",
        "min_time": 1,
        "format": "[$duration]($style) "
      },
      {
        "type": "jobs",
        "symbol": "пҖ“ ",
        "style": "red",
        "number_threshold": 1,
        "format": "[$symbol]($style)"
      },
      {
        "type": "aws",
        "symbol": "пү° ",
        "style": "yellow",
        "format": "[$symbol($profile )(\[$duration\] )]($style)"
      },
      {
        "type": "docker_context",
        "symbol": "пҢҲ ",
        "style": "fg:#06969A",
        "format": "[$symbol]($style) $path",
        "detect_files": ["docker-compose.yml", "docker-compose.yaml", "Dockerfile"],
        "detect_extensions": ["Dockerfile"]
      },
      {
        "type": "python",
        "style": "blue",
        "symbol": "оҲө ",
        "format": "[${symbol}${pyenv_prefix}(${version} )(\($virtualenv\) )]($style)",
        "pyenv_version_name": true,
        "pyenv_prefix": ""
      },
      {
        "type": "conda",
        "style": "bg:blue",
        "format": "[[ $symbol( $environment) ](fg:#surface0 bg:blue)]($style)",
        "symbol": "оҳҶ",
        "ignore_base": false
      },
      {
        "type": "lua",
        "symbol": "оҳ  "
      },
      {
        "type": "time",
        "disabled": false,
        "style": "bg:surface1 fg:lavender",
        "time_format": "%R",
        "format": "[$time](bold $style)[оӮҙ](surface1)"
      },
      {
        "type": "custom",
        "name": "live-clock-icon",
        "command": "echo \"оҺҒоҺӮоҺғоҺ„оҺ…оҺҶоҺҮоҺҲоҺүоҺҠоҺӢоҺҢпҖ—\" | cut -c $(($(date +%H)%12+1))",
        "when": true,
        "style": "bg:surface1 fg:lavender",
        "format": "[оӮ¶](surface1)[$output ]($style)"
      },
      {
        "type": "character",
        "success_symbol": "[пҒЎ](bold green) ",
        "error_symbol": "[пҖҚ пҒЎ](bold red) "
      },
      {
        "type": "package",
        "symbol": "у°Ҹ— "
      }
    ]
  },
  "palettes": {
    "catppuccin_mocha": {
      "rosewater": "#f5e0dc",
      "flamingo": "#f2cdcd",
      "pink": "#f5c2e7",
      "mauve": "#cba6f7",
      "red": "#f38ba8",
      "maroon": "#eba0ac",
      "peach": "#fab387",
      "yellow": "#f9e2af",
      "green": "#a6e3a1",
      "teal": "#94e2d5",
      "sky": "#89dceb",
      "sapphire": "#74c7ec",
      "blue": "#89b4fa",
      "lavender": "#b4befe",
      "text": "#cdd6f4",
      "subtext1": "#bac2de",
      "subtext0": "#a6adc8",
      "overlay2": "#9399b2",
      "overlay1": "#7f849c",
      "overlay0": "#6c7086",
      "surface2": "#585b70",
      "surface1": "#45475a",
      "surface0": "#313244",
      "base": "#1e1e2e",
      "mantle": "#181825",
      "crust": "#11111b"
    }
  },
  "add_newline": false
}


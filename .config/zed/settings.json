{
  "show_edit_predictions": true,
  "icon_theme": "VSCode Icons (Dark)",
  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-latest"
    },
    "version": "2"
  },
  "ssh_connections": [
    {
      "host": "login.devana.nscc.sk",
      "username": "dmosko",
      "port": 5522,
      "projects": [
        {
          "paths": ["~/ONIX"]
        },
        {
          "paths": ["~/cuda_cviko"]
        },
        {
          "paths": ["~/forward_simulations"]
        },
        {
          "paths": ["~/gaussian-splatting"]
        },
        {
          "paths": ["~/mhz_tomo_simulations"]
        }
      ]
    },
    {
      "host": "max-exfl-display.desy.de",
      "username": "dmosko",
      "projects": [
        {
          "paths": ["~/phase_ret"]
        },
        {
          "paths": ["~/robust_pca"]
        }
      ]
    },
    {
      "host": "login.devana.nscc.sk",
      "username": "dmosko",
      "port": 5522,
      "projects": []
    }
  ],
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte - No Italics",
    "dark": "One Dark Pro"
  },
  "buffer_font_size": 16,
  "buffer_line_height": {
    "custom": 1.2
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_weight": 500,
  "cursor_blink": false,

  // Line numbers, indent guides
  "relative_line_numbers": true,
  "preferred_line_length": 80,
  "wrap_guides": [88],
  "indent_guides": {
    "enabled": true,
    "active_line_width": 3,
    "coloring": "indent_aware"
  },
  "show_whitespaces": "selection",

  // Enable preconfigured inlay hints (Zed)
  "inlay_hints": {
    "enabled": true
  },

  // Zed panels configuration
  "tab_bar": {
    "show": false
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  // "toolbar": {
  //   "breadcrumbs": false,
  //   "quick_actions": false
  // },
  "scrollbar": {
    "show": "never"
  },
  "vertical_scroll_margin": 0,
  "chat_panel": {
    "button": "never"
  },
  "collaboration_panel": {
    "button": false
  },
  "project_panel": {
    "git_status": true
  },
  "centered_layout": {
    "left_padding": 0.2,
    "right_padding": 0.2
  },
  "features": {
    // Disable GitHub Copilot button
    "edit_prediction_provider": "zed"
  },

  // Git config
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },

  // Languages settings
  "languages": {
    "C++": {
      "formatter": {
        "external": {
          "command": "clang-format"
        }
      },
      "format_on_save": "on"
    },
    "Python": {
      "show_edit_predictions": false,
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "off",
      "formatter": [
        {
          "external": {
            "command": "bash",
            "arguments": [
              "-c",
              "ruff check --fix --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}"
            ]
          }
        },
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },

  // Languages settings
  // "languages": {
  //   "Python": {
  //     "language_servers": ["pyright", "ruff"],
  //     "format_on_save": "off",
  //     "formatter": {
  //       "external": {
  //         "command": "bash",
  //         "arguments": [
  //           "-c",
  //           "ruff check --select=I --fix --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}"
  //         ]
  //       }
  //     }
  //   }
  // },

  // "languages": {
  //   "Python": {
  //     "language_servers": ["ruff"],
  //     "format_on_save": "off",
  //     "formatter": [
  //       {
  //         "code_actions": {
  //           "source.organizeImports.ruff": true,
  //           "source.fixAll.ruff": true
  //         }
  //       },
  //       {
  //         "language_server": {
  //           "name": "ruff"
  //         }
  //       }
  //     ]
  //   }
  // },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          // Ruff server settings goes here
          "lineLength": 80,
          "lint": {
            "extendSelect": ["I"]
          }
        }
      }
    }
    // "rust-analyzer": {
    //   "initialization_options": {
    //     "inlayHints": {
    //       "maxLength": null,
    //       "lifetimeElisionHints": {
    //         "enable": "skip_trivial",
    //         "useParameterNames": true
    //       },
    //       "closureReturnTypeHints": {
    //         "enable": "always"
    //       }
    //     }
    //   }
    // }
  },

  // Misc.
  // Globs to match against file paths to determine if a file is private.
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secrets.yml"
  ],
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },

  // Telemetry
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}

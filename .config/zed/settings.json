{
  "vim_mode": true,
  "theme": {
    "mode": "system", // Adaptive theme
    "light": "Catppuccin Latte - No Italics",
    "dark": "Tokyo Night Storm"
  },
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "ui_font_family": "Helvetica Neue",
  "cursor_blink": false,

  // Line numbers, indent guides
  "relative_line_numbers": true,
  "preferred_line_length": 80,
  "wrap_guides": [88],
  "indent_guides": {
    "enabled": true,
    "active_line_width": 3,
    "coloring": "indent_aware"
  },
  "show_whitespaces": "boundary",

  // Enable preconfigured inlay hints (Zed)
  "inlay_hints": {
    "enabled": true
  },

  // Zed panels configuration
  "tab_bar": {
    "show": false
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },
  "scrollbar": {
    "show": "never"
  },
  "vertical_scroll_margin": 0,
  "chat_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "project_panel": {
    "git_status": true
  },
  "centered_layout": {
    "left_padding": 0.2,
    "right_padding": 0.2
  },
  "features": {
    // Disable GitHub Copilot button
    "inline_completion_provider": "none"
  },

  // Git config
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },

  // Languages settings
  "languages": {
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "off",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "ruff check --select=I --fix --stdin-filename {buffer_path} | ruff format --stdin-filename {buffer_path}"
          ]
        }
      }
    }
  },

  // Misc.
  // Globs to match against file paths to determine if a file is private.
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secrets.yml"
  ],
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },

  // Telemetry
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}

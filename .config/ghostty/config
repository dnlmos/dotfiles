shell-integration = zsh
mouse-hide-while-typing = true
scrollback-limit = 1000000
shell-integration-features=sudo

theme = koda-dark

#font-family = "JetBrainsMono Nerd Font Mono"
#font-family = "CommitMono"
font-family = "Iosevka Output Extended"
# variants for bold and italic styles
font-family-bold = "Iosevka Output Extended Bold"
font-family-italic = "Iosevka Output Extended Italic"
font-family-bold-italic = "Iosevka Output Extended Bold Italic"
#background-opacity = 0.95
#background-blur = 20
font-size = 14
font-thicken = true

cursor-style = bar

# window-decoration = none

confirm-close-surface = true
clipboard-read = allow
clipboard-write = allow
mouse-hide-while-typing = true
window-padding-x = 6
window-padding-balance = true
window-width = 85
window-height = 30
# macos-titlebar-proxy-icon = hidden
